# Base URL for backend requests. The app appends "/api" itself, so set ONLY the origin
# here — never include a "/api" suffix (that would double to "/api/api/...").
#   - Local dev:  "/"            (Vite proxy forwards /api/* to the backend)
#   - Deployed:   "https://your-backend.example.com"   (no path suffix)
VITE_API_BASE=https://your-backend.example.com
